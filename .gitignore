*.pt
*.ckpt
*.onnx
*.h5
*.hdf5
*.pkl
*.joblib
*.tflite
*.mlmodel
*.pb

# ── Data Files ──────────────────────────────────────────────────────────────
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.xlsx
*.xls

# ── Generated Reports & Figures ─────────────────────────────────────────────
adhd_xai_results.png
adhd_xai_results.json
individual_plots/

# ── Experiment Tracking ─────────────────────────────────────────────────────
wandb/
mlruns/
mlartifacts/
.lightning_logs/
runs/
tb_logs/

# ── Kaggle ──────────────────────────────────────────────────────────────────
.kaggle/

