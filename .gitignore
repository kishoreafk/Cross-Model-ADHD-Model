# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
.venv/
venv/
env/
.env/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
*.cover
*.log
.python-version

# ── Jupyter Notebooks ───────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Node / JavaScript ───────────────────────────────────────────────────────
node_modules/
*.tsbuildinfo
.npm
.eslintcache

# ── Build Outputs ───────────────────────────────────────────────────────────
dist/
build/
coverage/

# ── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── IDE & Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS Artifacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*

